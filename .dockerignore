# QuantSeed .dockerignore
# 构建 Docker 镜像时忽略的文件

# Python
__pycache__/
*.py[cod]
*.egg-info/

# 虚拟环境
venv/
.venv/

# IDE
.vscode/
.idea/

# Git
.git/
.gitignore

# 数据（通过 volume 挂载，不打包进镜像）
data/daily/*.csv
*.db

# 日志和输出
logs/
output/

# 环境变量
.env

# Docker 相关
Dockerfile*
docker-compose*
.docker/

# 测试文件
test_*.py
