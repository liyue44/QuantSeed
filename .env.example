# QuantSeed 环境变量配置模板
# ===============================
# 复制此文件为 .env 并修改对应值
#
# 本地开发：直接复制使用，默认 SQLite
# 阿里云部署：修改 DB_TYPE=postgresql 并填写数据库连接信息

# ==================== 数据库配置 ====================
# 数据库类型: sqlite (本地) | postgresql (生产)
DB_TYPE=sqlite

# SQLite 文件路径（仅 DB_TYPE=sqlite 时生效）
DB_PATH=data/quantseed.db

# PostgreSQL 连接（仅 DB_TYPE=postgresql 时生效）
PG_HOST=localhost
PG_PORT=5432
PG_USER=quantseed
PG_PASSWORD=changeme
PG_DATABASE=quantseed

# ==================== 应用配置 ====================
# 后端 API 地址
API_BASE_URL=http://localhost:8000

# 日志级别: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ==================== 策略配置 ====================
MA_FAST=20
MA_SLOW=60
INITIAL_CASH=1000000
POSITION_SIZE=0.95
COMMISSION_RATE=0.00025
SLIPPAGE=0.001

# ==================== 数据配置 ====================
DATA_START_DATE=20180101
